<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Ranil_Uchebka.Views.GanttChartView">
    <Border BorderBrush="#4867AC" BorderThickness="1" CornerRadius="6" Background="White" Padding="8">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="360">
            <Canvas x:Name="ChartCanvas" Width="960" Height="320"/>
        </ScrollViewer>
    </Border>
</UserControl>
