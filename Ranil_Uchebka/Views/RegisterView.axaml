<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Ranil_Uchebka.ViewModels"
             x:Class="Ranil_Uchebka.Views.RegisterView"
             x:DataType="vm:MainViewModel">
    <Grid Background="#F1F1F1">
        <Border Width="860"
                MaxWidth="860"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#FFFFFF"
                BorderBrush="#4867AC"
                BorderThickness="2"
                CornerRadius="16">
            <Grid ColumnDefinitions="310,*">
                <Border Background="#F3CC8D" CornerRadius="14,0,0,14" Padding="24">
                    <StackPanel VerticalAlignment="Center" Spacing="10">
                        <TextBlock Text="Новый пользователь"
                                   Foreground="#BB0C07"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Регистрация"
                                   Foreground="#000000"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Создайте аккаунт заказчика для оформления и контроля заказов."
                                   Foreground="#000000"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Margin="34,24" Spacing="10">
                    <TextBlock Text="Форма регистрации заказчика"
                               FontSize="18"
                               FontWeight="Bold"/>
                    <TextBlock Text="Роль пользователя: Заказчик" Foreground="#000000"/>

                    <TextBlock Text="ФИО" Margin="0,6,0,0"/>
                    <TextBox Text="{Binding RegisterFullName, Mode=TwoWay}" Watermark="Иванов Иван Иванович"/>
                    <TextBlock Text="Логин"/>
                    <TextBox Text="{Binding RegisterLogin, Mode=TwoWay}" Watermark="уникальный логин"/>
                    <TextBlock Text="Пароль"/>
                    <TextBlock Text="4-16 символов, без * &amp; { } | +, обязательны заглавная буква и цифра"
                               FontSize="11"
                               Foreground="#000000"
                               Margin="0,-4,0,0"
                               TextWrapping="Wrap"/>
                    <TextBox Text="{Binding RegisterPassword, Mode=TwoWay}" PasswordChar="●"/>

                    <Button Content="Завершить регистрацию"
                            Command="{Binding RegisterCustomerCommand}"
                            Classes="primary"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"/>

                    <TextBlock Text="{Binding RegisterError}"
                               Foreground="#BB0C07"
                               TextWrapping="Wrap"
                               MaxWidth="430"/>

                    <Border Height="1" Background="#F3CC8D" Margin="0,10,0,4"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Уже есть аккаунт?" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button Content="Перейти ко входу"
                                Command="{Binding OpenLoginPageCommand}"
                                Classes="link"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
